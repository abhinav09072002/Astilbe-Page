# AP Newsletter Frontend — Environment Variables
# Copy this to .env and fill in your values

# ── Development ──────────────────────────────────────
# Leave this EMPTY in development — the Vite proxy handles it automatically.
# The proxy in vite.config.js forwards /api → http://localhost:5000
VITE_API_URL=

# ── Production ───────────────────────────────────────
# When deploying (Vercel, Netlify, etc.), set this to your backend URL:
# VITE_API_URL=https://your-backend.railway.app/api
